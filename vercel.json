{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/src/app.js"
    },
    {
      "source": "/reports/(.*)",
      "destination": "backend/reports/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/((?!api/|reports/).*)",
      "destination": "/frontend/index.html"
    }
  ],
  "env": {
    "VERCEL": "1"
  }
}
